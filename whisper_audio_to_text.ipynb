# @title Step 1: 安裝 Whisper 和必要套件 (點擊左側播放鍵執行)
print("正在安裝環境，請稍候約 1 分鐘...")
!pip install git+https://github.com/openai/whisper.git -q
!apt update && apt install ffmpeg -y -q
!pip install pydub -q
print("✅ 環境安裝完成！")

# @title Step 2: 選擇音檔來源
# @markdown 你可以選擇從電腦「手動上傳」，或是掛載「Google 雲端硬碟」。
音檔來源 = "手動上傳" #@param ["手動上傳", "Google雲端硬碟"]

from google.colab import files
import os

if 音檔來源 == "手動上傳":
    print("請點擊下方按鈕上傳音檔（支援 mp3, wav, m4a 等）：")
    uploaded = files.upload()
    filename = list(uploaded.keys())[0]
else:
    from google.colab import drive
    drive.mount('/content/drive')
    #@markdown 如果選雲端硬碟，請在下方輸入雲端硬碟中音檔的完整路徑：
    filename = "/content/drive/MyDrive/your_folder/audio.mp3" #@param {type:"string"}
    if not os.path.exists(filename):
        raise FileNotFoundError(f"找不到檔案：{filename}，請檢查路徑是否正確。")

# @title Step 3: 將音檔切成 15 分鐘一段
from pydub import AudioSegment

print(f"正在載入音檔: {filename} ...")
audio = AudioSegment.from_file(filename)

chunk_length_ms = 15 * 60 * 1000  # 15 分鐘
chunks = [audio[i:i+chunk_length_ms] for i in range(0, len(audio), chunk_length_ms)]

chunk_files = []
for idx, chunk in enumerate(chunks):
    chunk_name = f"chunk_{idx}.mp3"
    chunk.export(chunk_name, format="mp3")
    chunk_files.append(chunk_name)

print(f"✂️ 已成功切成 {len(chunk_files)} 段，每段約 15 分鐘")

# @title Step 4: 逐段使用 Whisper 轉錄
import whisper

# @markdown 模型大小選擇（small 速度快、準確度適中；medium/large 更準但慢，需要開啟 GPU）
模型大小 = "small" #@param ["base", "small", "medium", "large"]

print(f"正在載入 Whisper {模型大小} 模型...")
model = whisper.load_model(模型大小)
all_text = ""

for idx, chunk_name in enumerate(chunk_files):
    print(f"正在轉錄第 {idx+1}/{len(chunk_files)} 段: {chunk_name} ...")
    # 加入 initial_prompt 可以有效減少錯別字，並強制輸出繁體中文
    result = model.transcribe(chunk_name, language="zh", initial_prompt="以下是繁體中文的逐字稿。")
    all_text += result["text"] + "\n\n"

# @title Step 5: 儲存與下載文字檔
output_name = "transcription.txt"
with open(output_name, "w", encoding="utf-8") as f:
    f.write(all_text)

print(f"✅ 轉錄完成！文字已存成 {output_name}")
files.download(output_name)
